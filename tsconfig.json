{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@vendix/types": ["packages/types"],
      "@vendix/utils": ["packages/utils"],
      "@vendix/database": ["packages/database"],
      "@vendix/billing-core": ["packages/billing-core"]
    }
  },
  "exclude": ["node_modules", "**/dist"]
}
