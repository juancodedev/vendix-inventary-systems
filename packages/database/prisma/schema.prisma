generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////
// ENUMS
//////////////////////////

enum RoleType {
  SUPER_ADMIN
  ADMIN
  SELLER
  DASHBOARD
  POS
}

enum LocationType {
  STORE
  WAREHOUSE
  VEHICLE
  OTHER
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

//////////////////////////
// CORE MULTITENANT
//////////////////////////

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String
  isActive  Boolean  @default(true)
  stripeCustomerId String?

  users      User[]
  locations  Location[]
  products   Product[]
  suppliers  Supplier[]
  purchases  PurchaseOrder[]
  auditLogs  AuditLog[]
  sales      Sale[]
  subscriptions Subscription[]
  usages        UsageMetric[]
  invoices      Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
}

model Plan {
  id          String          @id @default(uuid())
  code        String          @unique
  name        String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD")
  interval    BillingInterval
  stripePriceId String?
  features    Json
  limits      Json
  taxPercent  Decimal?        @db.Decimal(5, 2)
  isActive    Boolean         @default(true)
  displayOrder Int            @default(0)

  subscriptions      Subscription[] @relation("SubscriptionCurrentPlan")
  pendingSubscriptions Subscription[] @relation("SubscriptionPendingPlan")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, displayOrder])
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  planId               String
  plan                 Plan               @relation("SubscriptionCurrentPlan", fields: [planId], references: [id])
  pendingPlanId        String?
  pendingPlan          Plan?              @relation("SubscriptionPendingPlan", fields: [pendingPlanId], references: [id])
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  pendingChangeAtPeriodEnd Boolean        @default(false)
  externalId           String?            @unique

  invoices             Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([planId])
}

model UsageMetric {
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  metric     String
  value      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@id([tenantId, metric])
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         InvoiceStatus
  dueDate        DateTime?
  paidAt         DateTime?
  externalId     String?        @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status, createdAt])
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  email     String
  password  String
  role      RoleType

  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

//////////////////////////
// MULTISUCURSAL
//////////////////////////

model Location {
  id        String       @id @default(uuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  name      String
  type      LocationType

  inventories                   Inventory[]
  sales                         Sale[]
  inventoryMovements            InventoryMovement[] @relation("InventoryMovementLocation")
  sourceInventoryMovements      InventoryMovement[] @relation("InventoryMovementSourceLocation")
  destinationInventoryMovements InventoryMovement[] @relation("InventoryMovementDestinationLocation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

//////////////////////////
// PRODUCTOS
//////////////////////////

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  sku         String
  category    String?
  price       Decimal  @db.Decimal(10, 2)

  barcode     String?
  qrCode      String?

  isActive    Boolean  @default(true)

  inventories Inventory[]
  movements   InventoryMovement[]
  saleItems   SaleItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@unique([tenantId, sku])
  @@index([tenantId])
}

//////////////////////////
// INVENTARIO
//////////////////////////

model Inventory {
  id          String   @id @default(uuid())
  tenantId    String

  productId   String
  locationId  String

  product     Product  @relation(fields: [productId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])

  quantity    Int
  minStock    Int      @default(5)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([tenantId])
  @@index([tenantId, productId])
  @@index([tenantId, locationId])
}

model InventoryMovement {
  id          String        @id @default(uuid())
  tenantId    String

  productId   String
  locationId  String?
  product     Product       @relation(fields: [productId], references: [id])
  location    Location?     @relation("InventoryMovementLocation", fields: [locationId], references: [id])

  // For Transfers:
  sourceLocationId      String?
  destinationLocationId String?
  sourceLocation        Location? @relation("InventoryMovementSourceLocation", fields: [sourceLocationId], references: [id])
  destinationLocation   Location? @relation("InventoryMovementDestinationLocation", fields: [destinationLocationId], references: [id])

  type        MovementType
  quantity    Int

  reference   String? // venta, compra, ajuste
  notes       String?
  createdBy   String?

  createdAt   DateTime @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@index([tenantId, locationId])
}

//////////////////////////
// VENTAS (POS)
//////////////////////////

model Sale {
  id            String       @id @default(uuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  locationId    String
  location      Location     @relation(fields: [locationId], references: [id])
  
  userId        String
  user          User         @relation(fields: [userId], references: [id])

  status        SaleStatus
  subtotal      Decimal      @db.Decimal(10, 2)
  tax           Decimal      @default(0) @db.Decimal(10, 2)
  total         Decimal      @db.Decimal(10, 2)

  paymentMethod PaymentMethod
  clientReference String?
  notes         String?
  metadata      Json?
  syncedAt      DateTime?

  items         SaleItem[]

  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@unique([tenantId, clientReference])
}

model SaleItem {
  id        String   @id @default(uuid())

  saleId    String
  productId String

  quantity  Int
  price     Decimal  @db.Decimal(10, 2)

  sale      Sale     @relation(fields: [saleId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

//////////////////////////
// ORDENES DE COMPRA
//////////////////////////

model Supplier {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  name      String
  email     String?

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())

  @@index([tenantId])
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  status      String

  total       Decimal  @db.Decimal(10, 2)

  createdAt   DateTime @default(now())

  @@index([tenantId])
}

//////////////////////////
// AUDITORÍA
//////////////////////////

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  entity    String
  entityId  String

  action    String
  changes   Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
}
